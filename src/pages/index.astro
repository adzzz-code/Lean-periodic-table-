---
import Base from '../layouts/Base.astro';
import { families, levels } from '../data/families.js';
import { concepts } from '../data/concepts.js';
import { problems } from '../data/problems.js';
import { withBase } from '../lib/url.js';

// Index { level -> familyId -> [concepts] } pour la matrice.
const cellOf = (level, famId) =>
  concepts
    .filter((c) => c.level === level && c.family === famId)
    .sort((a, b) => a.number - b.number);

const featured = problems.filter((p) => p.featured);
---

<Base title={null}>
  <section class="hero">
    <div class="wrap">
      <h1>Le tableau périodique du Lean & de l'excellence opérationnelle</h1>
      <p>
        Les outils et méthodes des grandes entreprises, classés et expliqués — pensés pour être
        appliqués dans une TPE ou une petite équipe, avec leurs limites et leurs vrais premiers pas.
      </p>
      <p>
        Deux façons d'entrer : <strong>partez de votre problème</strong> (recommandé si vous débutez),
        ou <strong>explorez le tableau</strong> par famille et niveau de maturité.
      </p>
    </div>
  </section>

  <section class="start-here">
    <div class="wrap">
      <div class="start-head">
        <h2>Vous ne connaissez pas le Lean ? Partez de votre problème</h2>
        <a class="start-all" href={withBase('/diagnostic/')}>Tous les problèmes →</a>
      </div>
      <div class="start-grid">
        {
          featured.map((p) => (
            <a class="start-card" href={withBase(`/diagnostic/${p.slug}/`)}>
              <span class="start-q">« {p.problem} »</span>
              <span class="start-meta">{p.solutions.length} méthodes →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="wrap table-intro">
    <h2>Ou explorez le tableau complet</h2>
    <p>
      <strong>Colonnes</strong> = familles de concepts · <strong>Lignes</strong> = niveau de maturité
      (commencez en haut). Cliquez une case pour ouvrir la fiche.
    </p>
  </div>

  <div class="controls">
    <div class="wrap">
      <div class="control-group" id="family-filters">
        <span class="control-label">Familles</span>
        {
          families.map((f) => (
            <button class="chip-btn fam-btn" data-family={f.id} aria-pressed="true">
              <span class="fam-dot" style={`background:${f.color}`} />
              {f.short}
            </button>
          ))
        }
      </div>

      <div class="control-group" id="level-filters">
        <span class="control-label">Niveau</span>
        {
          levels.map((l) => (
            <button class="chip-btn lvl-btn" data-level={l.level} aria-pressed="true">
              {l.level}. {l.name}
            </button>
          ))
        }
      </div>

      <div class="control-group">
        <label class="toggle">
          <input type="checkbox" id="pme-toggle" />
          Mode TPE/PME (incontournables)
        </label>
      </div>

      <input
        class="search"
        id="search"
        type="search"
        placeholder="Rechercher un concept, un symbole…"
        aria-label="Rechercher un concept"
      />

      <span class="result-count" id="count" aria-live="polite"></span>
    </div>
  </div>

  <div class="wrap">
    <div class="legend">
      <span class="item"><strong>★</strong> = incontournable pour une petite structure</span>
      {
        levels.map((l) => (
          <span class="item">
            <strong>Niveau {l.level}</strong> {l.name} — {l.hint}
          </span>
        ))
      }
    </div>

    <div class="table-scroll">
      <div class="matrix">
        <div class="corner">Niveau ＼ Famille</div>
        {
          families.map((f) => (
            <div class="fam-head" style={`background:${f.color}`}>
              {f.name}
            </div>
          ))
        }

        {
          levels.map((l) => (
            <>
              <div class="level-head">
                <span class="n">Niveau {l.level}</span>
                {l.name}
              </div>
              {families.map((f) => {
                const cell = cellOf(l.level, f.id);
                return (
                  <div class={`cell${cell.length === 0 ? ' empty' : ''}`}>
                    {cell.map((c) => (
                      <a
                        class="el"
                        href={withBase(`/concept/${c.slug}/`)}
                        style={`--c:${f.color}`}
                        data-family={c.family}
                        data-level={c.level}
                        data-pme={c.pmeStarter ? '1' : '0'}
                        data-search={`${c.name} ${c.symbol} ${c.fullName}`.toLowerCase()}
                        aria-label={`${c.name} — famille ${f.name}, niveau ${l.level} (${l.name})${c.pmeStarter ? ', incontournable TPE/PME' : ''}`}
                      >
                        <span class="num">{c.number}</span>
                        <span class="sym">{c.symbol}</span>
                        <span class="nm">{c.name}</span>
                        {c.pmeStarter && (
                          <span class="star" title="Incontournable TPE/PME">
                            ★
                          </span>
                        )}
                      </a>
                    ))}
                  </div>
                );
              })}
            </>
          ))
        }
      </div>
    </div>
  </div>
</Base>

<script>
  const search = document.getElementById('search');
  const pmeToggle = document.getElementById('pme-toggle');
  const famButtons = Array.from(document.querySelectorAll('#family-filters .fam-btn'));
  const lvlButtons = Array.from(document.querySelectorAll('#level-filters .lvl-btn'));
  const els = Array.from(document.querySelectorAll('.el'));
  const count = document.getElementById('count');

  const activeFamilies = new Set(famButtons.map((b) => b.dataset.family));
  const activeLevels = new Set(lvlButtons.map((b) => b.dataset.level));

  // Normalise pour une recherche insensible à la casse ET aux accents.
  const norm = (s) =>
    (s || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase();

  function apply() {
    const terms = norm(search.value).split(/\s+/).filter(Boolean);
    const pmeOnly = pmeToggle.checked;
    let visible = 0;

    for (const el of els) {
      const famOk = activeFamilies.has(el.dataset.family);
      const lvlOk = activeLevels.has(el.dataset.level);
      const pmeOk = !pmeOnly || el.dataset.pme === '1';
      // Multi-mots : tous les termes doivent être présents (accents ignorés).
      const haystack = norm(el.dataset.search);
      const searchOk = terms.every((t) => haystack.includes(t));

      // Filtres (famille / niveau / mode PME) → on masque vraiment (la case se vide).
      const hidden = !famOk || !lvlOk || !pmeOk;
      el.classList.toggle('is-hidden', hidden);
      // Recherche → on grise les non-correspondants pour garder la structure du tableau.
      el.classList.toggle('is-dim', !hidden && terms.length > 0 && !searchOk);

      if (!hidden && searchOk) visible++;
    }
    count.textContent = `${visible} concept${visible > 1 ? 's' : ''} affiché${visible > 1 ? 's' : ''}`;
  }

  function toggleButton(btn, set, key) {
    const pressed = btn.getAttribute('aria-pressed') === 'true';
    btn.setAttribute('aria-pressed', String(!pressed));
    if (pressed) set.delete(key);
    else set.add(key);
    apply();
  }

  famButtons.forEach((btn) =>
    btn.addEventListener('click', () => toggleButton(btn, activeFamilies, btn.dataset.family)),
  );
  lvlButtons.forEach((btn) =>
    btn.addEventListener('click', () => toggleButton(btn, activeLevels, btn.dataset.level)),
  );

  search.addEventListener('input', apply);
  pmeToggle.addEventListener('change', apply);
  apply();
</script>
