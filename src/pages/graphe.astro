---
import Base from '../layouts/Base.astro';
import { concepts } from '../data/concepts.js';
import { families, familyById } from '../data/families.js';
import { withBase } from '../lib/url.js';

// Layout radial calculé au build : 8 familles en secteurs, rayon selon le niveau de maturité.
const W = 880;
const H = 760;
const cx = W / 2;
const cy = H / 2;
const R0 = 150;
const RL = 42;

const pos = {};
families.forEach((f, fi) => {
  const list = concepts.filter((c) => c.family === f.id).sort((a, b) => a.number - b.number);
  const a0 = (fi / families.length) * Math.PI * 2 - Math.PI / 2;
  const span = 0.5; // étalement angulaire à l'intérieur d'une famille
  const n = list.length;
  list.forEach((c, k) => {
    const off = n > 1 ? (k - (n - 1) / 2) * (span / (n - 1)) : 0;
    const ang = a0 + off;
    const rad = R0 + (c.level - 1) * RL;
    pos[c.slug] = { x: cx + rad * Math.cos(ang), y: cy + rad * Math.sin(ang), c, color: f.color };
  });
});

// Arêtes uniques (relations non orientées).
const seen = new Set();
const edges = [];
for (const c of concepts) {
  for (const r of c.related || []) {
    if (!pos[r]) continue;
    const key = [c.slug, r].sort().join('|');
    if (seen.has(key)) continue;
    seen.add(key);
    edges.push([c.slug, r]);
  }
}
---

<Base
  title="Vue graphe des concepts liés"
  description="La carte des relations entre les concepts Lean : prérequis et concepts liés, par famille."
>
  <article class="graph">
    <div class="wrap">
      <p class="breadcrumb"><a href={withBase('/')}>Tableau</a> › Graphe</p>
      <h1>La carte des relations</h1>
      <p class="lead">
        Les concepts ne vivent pas isolés : ils s’appuient les uns sur les autres. Survolez (ou
        touchez) un élément pour voir ce à quoi il est lié. Cliquez pour ouvrir sa fiche.
      </p>

      <div class="legend">
        {
          families.map((f) => (
            <span class="item">
              <span class="dot" style={`background:${f.color}`} />
              {f.short}
            </span>
          ))
        }
      </div>

      <div class="graph-scroll">
        <svg
          id="graph"
          viewBox={`0 0 ${W} ${H}`}
          role="img"
          aria-label="Graphe des relations entre concepts"
        >
          <g class="edges">
            {
              edges.map(([a, b]) => (
                <line
                  class="edge"
                  data-a={a}
                  data-b={b}
                  x1={pos[a].x}
                  y1={pos[a].y}
                  x2={pos[b].x}
                  y2={pos[b].y}
                />
              ))
            }
          </g>
          <g class="nodes">
            {
              concepts.map((c) => {
                const p = pos[c.slug];
                return (
                  <a
                    class="gnode"
                    href={withBase(`/concept/${c.slug}/`)}
                    data-slug={c.slug}
                    aria-label={`${c.name} (${familyById[c.family].name})`}
                  >
                    <circle cx={p.x} cy={p.y} r="16" style={`--c:${p.color}`} />
                    <text x={p.x} y={p.y} dy="0.35em" text-anchor="middle">
                      {c.symbol}
                    </text>
                  </a>
                );
              })
            }
          </g>
        </svg>
      </div>

      <p class="graph-foot">
        Vous cherchez une solution à un problème précis ?
        <a href={withBase('/diagnostic/')}>Partez de votre problème</a> · ou
        <a href={withBase('/')}>revenez au tableau</a>.
      </p>
    </div>
  </article>
</Base>

<style>
  .graph {
    padding: 22px 0 60px;
  }
  .graph h1 {
    font-size: clamp(1.5rem, 3.6vw, 2.1rem);
    letter-spacing: -0.02em;
    margin: 8px 0 10px;
  }
  .graph .lead {
    color: var(--ink);
    max-width: 66ch;
  }
  .legend {
    display: flex;
    gap: 12px 18px;
    flex-wrap: wrap;
    margin: 14px 0;
    font-size: 0.82rem;
    color: var(--ink-soft);
  }
  .legend .item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .legend .dot {
    width: 11px;
    height: 11px;
    border-radius: 3px;
  }
  .graph-scroll {
    overflow-x: auto;
  }
  #graph {
    width: 100%;
    min-width: 680px;
    height: auto;
    display: block;
  }
  .edge {
    stroke: #c4ced8;
    stroke-width: 1;
    opacity: 0.55;
  }
  .gnode circle {
    --c: #888;
    fill: #fff;
    stroke: var(--c);
    stroke-width: 2.5;
    transition:
      transform 0.1s,
      fill 0.1s;
  }
  .gnode text {
    font-size: 11px;
    font-weight: 800;
    fill: var(--ink);
    pointer-events: none;
  }
  .gnode {
    cursor: pointer;
  }
  .gnode:hover circle,
  .gnode:focus circle {
    fill: var(--c);
  }
  .gnode:hover text,
  .gnode:focus text {
    fill: #fff;
  }
  /* États pilotés en JS pour la surbrillance des relations */
  #graph.has-active .edge {
    opacity: 0.12;
  }
  #graph.has-active .edge.active {
    stroke: var(--brand);
    stroke-width: 2.5;
    opacity: 0.9;
  }
  #graph.has-active .gnode {
    opacity: 0.25;
  }
  #graph.has-active .gnode.active {
    opacity: 1;
  }
  .graph-foot {
    color: var(--ink-soft);
    margin-top: 22px;
  }
</style>

<script>
  const svg = document.getElementById('graph');
  const edges = Array.from(svg.querySelectorAll('.edge'));
  const nodes = Array.from(svg.querySelectorAll('.gnode'));

  // Voisinage à partir des arêtes du DOM.
  const neighbors = new Map();
  for (const e of edges) {
    const a = e.dataset.a;
    const b = e.dataset.b;
    if (!neighbors.has(a)) neighbors.set(a, new Set());
    if (!neighbors.has(b)) neighbors.set(b, new Set());
    neighbors.get(a).add(b);
    neighbors.get(b).add(a);
  }

  function activate(slug) {
    svg.classList.add('has-active');
    const linked = neighbors.get(slug) || new Set();
    for (const n of nodes) {
      const s = n.dataset.slug;
      n.classList.toggle('active', s === slug || linked.has(s));
    }
    for (const e of edges) {
      e.classList.toggle('active', e.dataset.a === slug || e.dataset.b === slug);
    }
  }
  function reset() {
    svg.classList.remove('has-active');
    nodes.forEach((n) => n.classList.remove('active'));
    edges.forEach((e) => e.classList.remove('active'));
  }

  nodes.forEach((n) => {
    const slug = n.dataset.slug;
    n.addEventListener('mouseenter', () => activate(slug));
    n.addEventListener('mouseleave', reset);
    n.addEventListener('focus', () => activate(slug));
    n.addEventListener('blur', reset);
  });
</script>
