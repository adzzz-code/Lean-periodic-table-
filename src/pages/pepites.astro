---
import Base from '../layouts/Base.astro';
import { quickwins } from '../data/quickwins.js';
import { conceptBySlug } from '../data/concepts.js';
import { familyById } from '../data/families.js';
import { withBase } from '../lib/url.js';

const home = new URL(withBase('/'), Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Tableau', item: home },
    { '@type': 'ListItem', position: 2, name: 'Pépites', item: canonical },
  ],
};
---

<Base
  title="Pépites : ce qui vous fait gagner du temps"
  description="Pas le temps ? Voici les méthodes Lean à plus fort retour pour une petite structure : gros gain, peu d'effort, et ce que chacune vous fait gagner concrètement."
  jsonld={[breadcrumb]}
>
  <article class="pepites">
    <div class="wrap">
      <p class="breadcrumb"><a href={withBase('/')}>Tableau</a> › Pépites</p>

      <h1>⚡ Pas le temps ? Commencez par les pépites</h1>
      <p class="lead">
        En petite structure, le temps est la ressource la plus rare. Voici les méthodes qui en
        <strong>font gagner le plus, pour le moins d'effort</strong> — sans budget ni expert. Prenez-en
        <strong>une</strong>, cette semaine.
      </p>

      <ol class="qw-list">
        {
          quickwins.map((q, i) => {
            const c = conceptBySlug[q.slug];
            const fam = familyById[c.family];
            return (
              <li class="qw">
                <a
                  class="qw-badge"
                  href={withBase(`/concept/${c.slug}/`)}
                  style={`--c:${fam.color}`}
                >
                  <span class="rank">{i + 1}</span>
                  <span class="sym">{c.symbol}</span>
                </a>
                <div class="qw-body">
                  <div class="qw-top">
                    <a class="qw-name" href={withBase(`/concept/${c.slug}/`)}>
                      {c.name}
                    </a>
                    <span class="qw-est" title="Estimation indicative">
                      ⏱ {q.estimate}*
                    </span>
                  </div>
                  <p class="qw-gain">{q.gain}</p>
                  <p class="qw-meta">
                    <span class="tag fam" style={`background:${fam.color}`}>
                      {fam.name}
                    </span>
                    <span class="tag win">Fort impact · faible effort</span>
                  </p>
                </div>
              </li>
            );
          })
        }
      </ol>

      <p class="pepites-note">
        * Estimations indicatives, en ordre de grandeur. Le gain réel dépend de votre activité et de
        votre point de départ — l’objectif est de montrer que ces méthodes <em>libèrent</em> du temps,
        pas de promettre un chiffre exact.
      </p>

      <p class="pepites-foot">
        Vous avez un besoin précis ? <a href={withBase('/diagnostic/')}>Partez de votre problème</a>
        · ou <a href={withBase('/')}>explorez le tableau complet</a>.
      </p>
    </div>
  </article>
</Base>

<style>
  .pepites {
    padding: 22px 0 60px;
  }
  .pepites h1 {
    font-size: clamp(1.5rem, 3.6vw, 2.2rem);
    letter-spacing: -0.02em;
    margin: 8px 0 10px;
  }
  .pepites .lead {
    font-size: 1.1rem;
    color: var(--ink);
    max-width: 64ch;
  }
  .qw-list {
    list-style: none;
    padding: 0;
    margin: 22px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .qw {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 14px 16px;
    box-shadow: var(--shadow);
  }
  .qw-badge {
    --c: #888;
    position: relative;
    flex: 0 0 auto;
    width: 56px;
    height: 56px;
    border-radius: 10px;
    border: 1px solid var(--line);
    border-top: 4px solid var(--c);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    text-decoration: none;
  }
  .qw-badge .sym {
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--ink);
  }
  .qw-badge .rank {
    position: absolute;
    top: -8px;
    left: -8px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .qw-body {
    flex: 1;
  }
  .qw-name {
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--ink);
    text-decoration: none;
  }
  .qw-name:hover {
    color: var(--brand);
  }
  .qw-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
  }
  .qw-est {
    flex: 0 0 auto;
    font-weight: 800;
    font-size: 0.82rem;
    color: #15803d;
    background: #e8f4ee;
    border: 1px solid #bfe3cd;
    border-radius: 999px;
    padding: 2px 10px;
    white-space: nowrap;
  }
  .qw-gain {
    margin: 4px 0 8px;
    color: var(--ink);
  }
  .qw-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 0;
  }
  .tag.win {
    background: #e8f4ee;
    color: #15803d;
    border-color: #bfe3cd;
  }
  .pepites-note {
    color: var(--ink-soft);
    font-size: 0.85rem;
    font-style: italic;
    margin: 18px 0 0;
    max-width: 70ch;
  }
  .pepites-foot {
    color: var(--ink-soft);
    margin-top: 18px;
  }
</style>
