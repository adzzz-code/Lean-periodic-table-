---
import Base from '../layouts/Base.astro';
import { quickwins } from '../data/quickwins.js';
import { conceptBySlug } from '../data/concepts.js';
import { familyById } from '../data/families.js';
import { withBase } from '../lib/url.js';

const home = new URL(withBase('/'), Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Tableau', item: home },
    { '@type': 'ListItem', position: 2, name: 'Pépites', item: canonical },
  ],
};
---

<Base
  title="Pépites : ce qui vous fait gagner du temps"
  description="Pas le temps ? Voici les méthodes Lean à plus fort retour pour une petite structure : gros gain, peu d'effort, et ce que chacune vous fait gagner concrètement."
  jsonld={[breadcrumb]}
>
  <article class="pepites">
    <div class="wrap">
      <p class="breadcrumb"><a href={withBase('/')}>Tableau</a> › Pépites</p>

      <h1>⚡ Pas le temps ? Commencez par les pépites</h1>
      <p class="lead">
        En petite structure, le temps est la ressource la plus rare. Voici les méthodes qui en
        <strong>font gagner le plus, pour le moins d'effort</strong> — sans budget ni expert. Prenez-en
        <strong>une</strong>, cette semaine.
      </p>

      <section class="calc" aria-label="Calculateur de gain">
        <div class="calc-row">
          <label for="rate">Votre coût horaire</label>
          <span class="calc-input">
            <input id="rate" type="number" value="35" min="0" step="5" inputmode="numeric" />
            <span>€/h</span>
          </span>
          <span class="calc-hint">(salaire chargé, ou ce que vaut votre heure)</span>
        </div>
        <p class="calc-out">
          En adoptant ces pépites, vous pourriez libérer <strong id="tot-h">0</strong> h/semaine — soit
          <strong id="tot-month">0 €</strong>/mois, <strong id="tot-year">0 €</strong>/an.
        </p>
        <p class="calc-why">
          Un gain de temps n’est pas ponctuel : il <strong>revient chaque semaine</strong>. C’est
          pourquoi le cumul annuel surprend autant.
        </p>
      </section>

      <ol class="qw-list">
        {
          quickwins.map((q, i) => {
            const c = conceptBySlug[q.slug];
            const fam = familyById[c.family];
            return (
              <li class="qw">
                <a
                  class="qw-badge"
                  href={withBase(`/concept/${c.slug}/`)}
                  style={`--c:${fam.color}`}
                >
                  <span class="rank">{i + 1}</span>
                  <span class="sym">{c.symbol}</span>
                </a>
                <div class="qw-body">
                  <div class="qw-top">
                    <a class="qw-name" href={withBase(`/concept/${c.slug}/`)}>
                      {c.name}
                    </a>
                    <span class="qw-badges">
                      <span class="qw-est" title="Estimation indicative">
                        ⏱ {q.estimate}*
                      </span>
                      <span class="qw-eur" data-hours={q.hoursPerWeek} />
                    </span>
                  </div>
                  <p class="qw-gain">{q.gain}</p>
                  <p class="qw-meta">
                    <span class="tag fam" style={`background:${fam.color}`}>
                      {fam.name}
                    </span>
                    <span class="tag win">Fort impact · faible effort</span>
                  </p>
                </div>
              </li>
            );
          })
        }
      </ol>

      <p class="pepites-note">
        * Estimations indicatives, en ordre de grandeur. Le gain réel dépend de votre activité et de
        votre point de départ — l’objectif est de montrer que ces méthodes <em>libèrent</em> du temps,
        pas de promettre un chiffre exact.
      </p>

      <p class="pepites-foot">
        Vous avez un besoin précis ? <a href={withBase('/diagnostic/')}>Partez de votre problème</a>
        · ou <a href={withBase('/')}>explorez le tableau complet</a>.
      </p>
    </div>
  </article>
</Base>

<style>
  .pepites {
    padding: 22px 0 60px;
  }
  .pepites h1 {
    font-size: clamp(1.5rem, 3.6vw, 2.2rem);
    letter-spacing: -0.02em;
    margin: 8px 0 10px;
  }
  .pepites .lead {
    font-size: 1.1rem;
    color: var(--ink);
    max-width: 64ch;
  }
  .calc {
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 4px solid var(--brand);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 16px 18px;
    margin: 20px 0 6px;
  }
  .calc-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .calc-row label {
    font-weight: 700;
  }
  .calc-input {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .calc-input input {
    width: 92px;
    padding: 8px 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    font-size: 1rem;
    color: var(--ink);
  }
  .calc-input input:focus {
    outline: 2px solid var(--brand);
    outline-offset: 1px;
  }
  .calc-hint {
    color: var(--ink-soft);
    font-size: 0.85rem;
  }
  .calc-out {
    font-size: 1.15rem;
    margin: 14px 0 6px;
  }
  .calc-out strong {
    color: var(--brand);
  }
  .calc-why {
    color: var(--ink-soft);
    font-size: 0.9rem;
    margin: 0;
  }
  .qw-badges {
    display: inline-flex;
    gap: 6px;
    flex-wrap: wrap;
    flex: 0 0 auto;
  }
  .qw-eur {
    font-weight: 800;
    font-size: 0.82rem;
    color: var(--brand);
    background: rgba(22, 104, 160, 0.08);
    border: 1px solid rgba(22, 104, 160, 0.25);
    border-radius: 999px;
    padding: 2px 10px;
    white-space: nowrap;
  }
  .qw-eur:empty {
    display: none;
  }
  .qw-list {
    list-style: none;
    padding: 0;
    margin: 22px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .qw {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 14px 16px;
    box-shadow: var(--shadow);
  }
  .qw-badge {
    --c: #888;
    position: relative;
    flex: 0 0 auto;
    width: 56px;
    height: 56px;
    border-radius: 10px;
    border: 1px solid var(--line);
    border-top: 4px solid var(--c);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    text-decoration: none;
  }
  .qw-badge .sym {
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--ink);
  }
  .qw-badge .rank {
    position: absolute;
    top: -8px;
    left: -8px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .qw-body {
    flex: 1;
  }
  .qw-name {
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--ink);
    text-decoration: none;
  }
  .qw-name:hover {
    color: var(--brand);
  }
  .qw-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
  }
  .qw-est {
    flex: 0 0 auto;
    font-weight: 800;
    font-size: 0.82rem;
    color: #15803d;
    background: #e8f4ee;
    border: 1px solid #bfe3cd;
    border-radius: 999px;
    padding: 2px 10px;
    white-space: nowrap;
  }
  .qw-gain {
    margin: 4px 0 8px;
    color: var(--ink);
  }
  .qw-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 0;
  }
  .tag.win {
    background: #e8f4ee;
    color: #15803d;
    border-color: #bfe3cd;
  }
  .pepites-note {
    color: var(--ink-soft);
    font-size: 0.85rem;
    font-style: italic;
    margin: 18px 0 0;
    max-width: 70ch;
  }
  .pepites-foot {
    color: var(--ink-soft);
    margin-top: 18px;
  }
</style>

<script>
  const WEEKS_PER_MONTH = 4.33;
  const WEEKS_PER_YEAR = 52;
  const rate = document.getElementById('rate');
  const eurCells = Array.from(document.querySelectorAll('.qw-eur'));
  const totH = document.getElementById('tot-h');
  const totMonth = document.getElementById('tot-month');
  const totYear = document.getElementById('tot-year');

  const euro = (n) => `${Math.round(n).toLocaleString('fr-FR')} €`;
  const round10 = (n) => Math.round(n / 10) * 10;

  function compute() {
    const r = Math.max(0, parseFloat(rate.value) || 0);
    let totalHours = 0;
    for (const cell of eurCells) {
      const h = parseFloat(cell.dataset.hours) || 0;
      totalHours += h;
      cell.textContent = r > 0 ? `≈ ${euro(h * r * WEEKS_PER_MONTH)}/mois` : '';
    }
    totH.textContent = Number.isInteger(totalHours) ? totalHours : totalHours.toFixed(1);
    totMonth.textContent = euro(round10(totalHours * r * WEEKS_PER_MONTH));
    totYear.textContent = euro(round10(totalHours * r * WEEKS_PER_YEAR));
  }

  rate.addEventListener('input', compute);
  compute();
</script>
