---
import Base from '../../layouts/Base.astro';
import { problems } from '../../data/problems.js';
import { withBase } from '../../lib/url.js';
---

<Base
  title="Par où commencer ? Partez de votre problème"
  description="Vous ne connaissez pas le Lean ? Choisissez le problème qui vous parle, on vous oriente vers les bonnes méthodes — sans jargon."
>
  <section class="diag-hero">
    <div class="wrap">
      <p class="breadcrumb"><a href={withBase('/')}>Tableau</a> › Par où commencer</p>
      <h1>Quel est votre problème ?</h1>
      <p class="lead">
        Pas besoin de connaître le Lean. Choisissez la situation qui vous parle : on vous oriente
        vers 3 à 4 méthodes utiles, expliquées simplement, et par quoi commencer.
      </p>
    </div>
  </section>

  <div class="wrap">
    <div class="problem-grid">
      {
        problems.map((p) => (
          <a class="problem-card" href={withBase(`/diagnostic/${p.slug}/`)}>
            <span class="problem-q">« {p.problem} »</span>
            <span class="problem-meta">{p.solutions.length} méthodes →</span>
          </a>
        ))
      }
    </div>

    <p class="diag-foot">
      Vous préférez explorer librement ? <a href={withBase('/')}>Voir le tableau complet</a>.
    </p>
  </div>
</Base>

<style>
  .diag-hero {
    padding: 26px 0 4px;
  }
  .diag-hero h1 {
    font-size: clamp(1.6rem, 4vw, 2.3rem);
    letter-spacing: -0.02em;
    margin: 6px 0 10px;
  }
  .diag-hero .lead {
    color: var(--ink-soft);
    max-width: 66ch;
    font-size: 1.05rem;
  }
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
    margin: 20px 0 26px;
  }
  .problem-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 14px;
    min-height: 104px;
    padding: 16px 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 4px solid var(--brand);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    text-decoration: none;
    color: var(--ink);
    transition:
      transform 0.1s,
      box-shadow 0.1s;
  }
  .problem-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(15, 28, 46, 0.12);
  }
  .problem-q {
    font-weight: 700;
    font-size: 1.02rem;
    line-height: 1.3;
  }
  .problem-meta {
    font-size: 0.82rem;
    color: var(--brand);
    font-weight: 700;
  }
  .diag-foot {
    color: var(--ink-soft);
    margin: 4px 0 40px;
  }
</style>
